{
  "manifest_version": 3,
  "name": "XAUUSD ICT Sentinel",
  "version": "1.0.0",
  "description": "Institutional AI Trading Assistant for XAUUSD on TradingView",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "https://www.tradingview.com/*",
    "http://localhost:3000/*",
    "https://*.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/*"],
      "js": ["dataExtractor.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "XAUUSD ICT Sentinel"
  },
  "options_page": "options.html"
}
